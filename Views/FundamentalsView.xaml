<Page
    x:Class="CryptoPortfolioTracker.Views.FundamentalsView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CryptoPortfolioTracker.ViewModels"
    xmlns:converters="using:CryptoPortfolioTracker.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="View_Loaded"
    Unloaded="View_Unloaded"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="TransparentListViewItem" TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="16,12,16,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Fundamentals" FontSize="24" FontWeight="SemiBold" Foreground="DarkGoldenrod"/>
                <TextBlock Text="Objectieve fundamentele score (0-100) per coin — haal per coin de cijfers op via 'Analyseer'"
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Right">
                <!-- Rij A: zoeken + filters -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox PlaceholderText="Zoek coin…" Width="160"
                             Text="{x:Bind _viewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTipService.ToolTip="Filter op naam of ticker"/>
                    <ToggleSwitch OnContent="★ favorieten" OffContent="alle coins" MinWidth="0"
                                  IsOn="{x:Bind _viewModel.OnlyFavorites, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Toon alleen je favoriete coins"/>
                    <ToggleSwitch OnContent="geanalyseerd" OffContent="alle" MinWidth="0"
                                  IsOn="{x:Bind _viewModel.OnlyAnalyzed, Mode=TwoWay}"
                                  ToolTipService.ToolTip="Toon alleen coins waarvoor al fundamentals zijn opgehaald"/>
                </StackPanel>
                <!-- Rij B: versheid + acties -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Vers ≤" VerticalAlignment="Center" FontSize="12"/>
                    <NumberBox Value="{x:Bind _viewModel.FreshnessDaysValue, Mode=TwoWay}"
                               Minimum="1" Maximum="90" SpinButtonPlacementMode="Compact" Width="96"
                               ToolTipService.ToolTip="Aantal dagen dat opgehaalde data als 'vers' geldt; daarna 'verouderd'"/>
                    <TextBlock Text="dagen" VerticalAlignment="Center" FontSize="12"/>
                    <TextBlock Text="{x:Bind _viewModel.FavoritesCountText, Mode=OneWay}"
                               VerticalAlignment="Center" FontSize="11" Opacity="0.7" Margin="6,0,2,0"/>
                    <Button Content="↻ Herladen"
                            Command="{x:Bind _viewModel.RefreshCommand}"
                            ToolTipService.ToolTip="Herlaad uit de database (geen API-calls)"/>
                    <Button Content="★ Favorieten"
                            Command="{x:Bind _viewModel.RefreshFavoritesCommand}"
                            IsEnabled="{x:Bind _viewModel.CanBatch, Mode=OneWay}"
                            ToolTipService.ToolTip="Ververs de fundamentals van je favoriete coins (max 10)"/>
                    <Button Content="⤓ Verouderde"
                            Command="{x:Bind _viewModel.RefreshStaleCommand}"
                            IsEnabled="{x:Bind _viewModel.CanBatch, Mode=OneWay}"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Haalt alleen ontbrekende of verouderde coins op — verse worden overgeslagen om API-calls te besparen"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Column headers -->
        <Grid Grid.Row="1" Margin="14,0,14,6" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="44"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="280"/>
                <ColumnDefinition Width="Auto" MinWidth="110"/>
                <ColumnDefinition Width="Auto" MinWidth="180"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Coin" FontSize="11" Opacity="0.7"/>
            <TextBlock Grid.Column="2" Text="Waardering &amp; aanbod" FontSize="11" Opacity="0.7"
                       ToolTipService.ToolTip="Market cap, FDV, 24u-volume, volume/market-cap-ratio en circulerend aanbod"/>
            <TextBlock Grid.Column="3" Text="Score" FontSize="11" Opacity="0.7" HorizontalAlignment="Center"
                       ToolTipService.ToolTip="Fundamental Score (0-100) en verdict"/>
            <TextBlock Grid.Column="4" Text="Acties" FontSize="11" Opacity="0.7" HorizontalAlignment="Right"/>
        </Grid>

        <!-- List -->
        <ListView Grid.Row="2"
                  ItemsSource="{x:Bind _viewModel.Rows, Mode=OneWay}"
                  SelectionMode="None"
                  ItemContainerStyle="{StaticResource TransparentListViewItem}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FundamentalRow">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="280"/>
                                <ColumnDefinition Width="Auto" MinWidth="110"/>
                                <ColumnDefinition Width="Auto" MinWidth="180"/>
                            </Grid.ColumnDefinitions>

                            <!-- Logo -->
                            <Image Grid.Column="0" Source="{x:Bind ImageUri}" Width="36" Height="36" VerticalAlignment="Center"/>

                            <!-- Name + community/dev -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind Name}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Symbol}" FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind RankText, Mode=OneWay}" FontSize="11" Opacity="0.7" VerticalAlignment="Center"
                                               ToolTipService.ToolTip="Market-cap rang"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind CommunityText, Mode=OneWay}" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind DevText, Mode=OneWay}" FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="320"/>
                            </StackPanel>

                            <!-- Valuation & supply -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="MC" FontSize="10" Width="34" Opacity="0.7"/>
                                    <TextBlock Text="{x:Bind MarketCapText, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" Width="74"/>
                                    <TextBlock Text="Vol/MC" FontSize="10" Width="44" Opacity="0.7"
                                               ToolTipService.ToolTip="24u-volume gedeeld door market cap — liquiditeitsmaat"/>
                                    <TextBlock Text="{x:Bind VolMcText, Mode=OneWay}" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="FDV" FontSize="10" Width="34" Opacity="0.7"
                                               ToolTipService.ToolTip="Fully Diluted Valuation"/>
                                    <TextBlock Text="{x:Bind FdvText, Mode=OneWay}" FontSize="11" Width="74"/>
                                    <TextBlock Text="FDV/MC" FontSize="10" Width="44" Opacity="0.7"
                                               ToolTipService.ToolTip="Verwateringsoverhang: hoe veel hoger de FDV is dan de huidige market cap"/>
                                    <TextBlock Text="{x:Bind FdvMcText, Mode=OneWay}" FontSize="11"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Circ" FontSize="10" Width="34" Opacity="0.7"
                                               ToolTipService.ToolTip="Circulerend aanbod"/>
                                    <TextBlock Text="{x:Bind CirculatingText, Mode=OneWay}" FontSize="11" Width="74"/>
                                    <TextBlock Text="{x:Bind AthText, Mode=OneWay}" FontSize="11" Opacity="0.8"
                                               ToolTipService.ToolTip="Afstand tot all-time high"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind TvlText, Mode=OneWay}" FontSize="11" Opacity="0.8"
                                           Visibility="{x:Bind HasTvl, Mode=OneWay}"
                                           ToolTipService.ToolTip="Total Value Locked (DefiLlama) — alleen voor DeFi-protocollen"/>
                            </StackPanel>

                            <!-- Score badge + verdict -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="3">
                                <Border CornerRadius="8" Padding="12,4" HorizontalAlignment="Center"
                                        Background="{x:Bind ScoreBrush, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind TotalScoreText, Mode=OneWay}"
                                               FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Bind Verdict, Mode=OneWay}" FontSize="10" HorizontalAlignment="Center"
                                           TextAlignment="Center" MaxWidth="110" TextWrapping="Wrap"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind DataScoreText, Mode=OneWay}" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                <!-- Versheid: leeftijd + 'verouderd' wanneer > 7 dagen -->
                                <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center"
                                            Visibility="{x:Bind HasData, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind AgeText, Mode=OneWay}" FontSize="9"
                                               Foreground="{x:Bind FreshnessBrush, Mode=OneWay}"
                                               ToolTipService.ToolTip="{x:Bind UpdatedText, Mode=OneWay}"/>
                                    <TextBlock Text="{x:Bind StalenessText, Mode=OneWay}" FontSize="9"
                                               Foreground="{x:Bind FreshnessBrush, Mode=OneWay}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Actions -->
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                <Button Content="{x:Bind FavoriteGlyph, Mode=OneWay}"
                                        Foreground="{x:Bind FavoriteBrush, Mode=OneWay}"
                                        FontSize="16" Padding="6,2" Background="Transparent" BorderThickness="0"
                                        Command="{Binding DataContext.ToggleFavoriteCommand, ElementName=RootPage}"
                                        CommandParameter="{Binding}"
                                        ToolTipService.ToolTip="Markeer als favoriet (max 10)"/>
                                <Button Content="{x:Bind AnalyzeLabel, Mode=OneWay}"
                                        IsEnabled="{x:Bind CanAnalyze, Mode=OneWay}"
                                        Command="{Binding DataContext.AnalyzeCommand, ElementName=RootPage}"
                                        CommandParameter="{Binding}"
                                        ToolTipService.ToolTip="Haal de fundamentals op bij CoinGecko en (her)bereken de score"/>
                                <Button Content="Detail"
                                        Click="Detail_Click" Tag="{Binding}"
                                        IsEnabled="{x:Bind HasData, Mode=OneWay}"
                                        ToolTipService.ToolTip="Toon alle fundamentele cijfers en de factor-onderbouwing"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Empty state -->
        <Border Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                Visibility="{x:Bind converters:Functions.FalseToVisible(_viewModel.HasRows), Mode=OneWay}">
            <StackPanel Spacing="6" MaxWidth="420">
                <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Geen coins" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Voeg coins toe via de Coin Library, of pas je zoekfilter aan."
                           FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="3" Text="{x:Bind _viewModel.StatusText, Mode=OneWay}"
                   FontSize="11" Margin="2,8,0,0"
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
    </Grid>
</Page>
