<Page
    x:Class="CryptoPortfolioTracker.Views.HelpView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CryptoPortfolioTracker.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="View_Loaded"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid CornerRadius="8,8,0,0"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Margin="0,0,5,10" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="110"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <controls:HomePageHeaderImage Grid.Row="0" Grid.RowSpan="3" Height="265" VerticalAlignment="Top"/>

            <!-- Header -->
            <RelativePanel>
                <TextBlock AutomationProperties.AutomationId="__ClickableAreaTextBlock"/>
                <TextBlock x:Name="appTitle"
                           Text="Crypto Portfolio Tracker Plus"
                           Foreground="DarkGoldenrod"
                           Margin="36,0,0,0"
                           VerticalAlignment="Top"
                           Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="txtPortfolio"
                           Foreground="DarkGoldenrod"
                           Margin="36,0,0,0"
                           Style="{StaticResource SubSampleHeaderTextStyle}"
                           RelativePanel.Below="appTitle"/>
                <TextBlock x:Name="txtTitle"
                           Text="Help &amp; Gebruikshandleiding"
                           Foreground="DarkGoldenrod"
                           Margin="36,5,0,0"
                           Style="{StaticResource SampleHeaderTextStyle}"
                           RelativePanel.Below="txtPortfolio"/>
            </RelativePanel>

            <!-- Explainer -->
            <TextBlock Grid.Row="1" VerticalAlignment="Bottom"
                       Style="{StaticResource ExplainerTextStyle}"
                       Margin="35,0,20,20" TextWrapping="Wrap"
                       Text="Uitleg van alle functies, berekeningen en instellingen. Klik op een onderwerp om het uit te klappen."/>

            <!-- Content -->
            <Border Grid.Row="2" VerticalAlignment="Stretch" Margin="10,0,5,0">
                <ScrollViewer VerticalScrollMode="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Disabled"
                              Padding="0,0,16,0">
                    <StackPanel x:Name="ContentPanel" Margin="4,8,4,24" Spacing="6"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
