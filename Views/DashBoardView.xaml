<Page
    x:Class="CryptoPortfolioTracker.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CryptoPortfolioTracker"
    xmlns:models="using:CryptoPortfolioTracker.Models"
    xmlns:enums="using:CryptoPortfolioTracker.Enums"
    xmlns:helpers="using:CryptoPortfolioTracker.Helpers"
    xmlns:viewmodels="using:CryptoPortfolioTracker.ViewModels"
    xmlns:converters="using:CryptoPortfolioTracker.Converters"
    xmlns:l="using:WinUI3Localizer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    d:DataContext="{d:DesignInstance Type=viewmodels:DashboardViewModel}"
    xmlns:controls="using:CryptoPortfolioTracker.Controls"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Loaded="View_Loaded"
    Loading="View_Loading"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="HorizontalSwipe" TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" >

        <Grid x:Name="dashboardGrid" CornerRadius="8,8,0,0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" 
              Margin="0,0,5,0" VerticalAlignment="Stretch" >
            <Grid.RowDefinitions>
                <RowDefinition Height="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'13*','Other'), Mode=OneWay}"/>
                <RowDefinition Height="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'33*','HeatMap+PiePortfolio'), Mode=OneWay}"/>
                <RowDefinition Height="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'38*','Graph+PieAccounts'), Mode=OneWay}"/>
                <RowDefinition Height="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'32*','Top5'), Mode=OneWay}"/>
                <RowDefinition Height="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'220','SignalsWidget'), Mode=OneWay}"/>
                <RowDefinition Height="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'46','FearGreedBar'), Mode=OneWay}"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'41*','HeatMap+Graph'), Mode=OneWay}"/>
                <ColumnDefinition Width="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'26*','PiePortfolio+PieAccounts'), Mode=OneWay}"/>
                <ColumnDefinition Width="{x:Bind converters:Functions.FullScreenToGridDef(_viewModel.ToggleFsMode,'33*','PieNarratives'), Mode=OneWay}"/>
            </Grid.ColumnDefinitions>
            
            <controls:HomePageHeaderImage Grid.Row="0" Grid.Column="0" Grid.RowSpan="4" Grid.ColumnSpan="3" 
                                          Opacity="0.1" Margin="0,0,0,0" VerticalAlignment="Stretch"/>
            <RelativePanel Grid.Row="0"  Grid.Column="0" Grid.ColumnSpan="3" >
                <TextBlock x:Name="txtDashboard" l:Uids.Uid="Dashboard_Title" Foreground="DarkGoldenrod" Margin="10,0,0,0" VerticalAlignment="Top" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="txtPortfolio" Margin="10,0,0,0" Text="{Binding PortfolioName}"  Foreground="DarkGoldenrod" Style="{StaticResource SubSampleHeaderTextStyle}" 
                           RelativePanel.Below="txtDashboard" />
                 <helpers:CustomBtn x:Name="btnPrivacy" 
                    Padding="2,2,2,2" 
                    Margin="8,5,0,3" 
                    Width="25"
                    Height="25"
                    Style="{StaticResource MK_ButtonStyle}" 
                    BorderThickness="0" 
                    Background="Transparent"
                    Command="{Binding TogglePrivacyModeCommand}" 
                    RelativePanel.RightOf="txtDashboard" RelativePanel.AlignBottomWith="txtDashboard" 
                    ToolTipService.ToolTip="Toggle privacy">
                    <FontIcon Glyph="{Binding GlyphPrivacy}" FontSize="18" FontWeight="Normal" Height="20" Width="20" />
                </helpers:CustomBtn>

                <helpers:CustomBtn x:Name="btnSettings"
                    Padding="2,2,2,2"
                    Margin="5,5,0,3"
                    Width="25"
                    Height="25"
                    Style="{StaticResource MK_ButtonStyle}"
                    BorderThickness="0"
                    Background="Transparent"
                    Command="{Binding ShowSettingsDialogCommand}"
                    RelativePanel.RightOf="btnPrivacy" RelativePanel.AlignBottomWith="btnPrivacy"
                    ToolTipService.ToolTip="Dashboard Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="18" FontWeight="Normal" Height="20" Width="20" />
                </helpers:CustomBtn>

            </RelativePanel>

            <controls:HeatMapControl  x:Name="heatMap" x:FieldModifier="public" Grid.Row="1" Grid.Column="0" Margin="10,0,0,0" HorizontalAlignment="Stretch" />
            <controls:GraphControl  x:Name="GraphControl" Grid.Row="2" Grid.Column="0" Margin="10,0,0,0" HorizontalAlignment="Stretch" />
            <!-- Col 1: 3 pie charts in een sub-grid met 3 gelijke rijen -->
            <Grid Grid.Row="1" Grid.Column="1" Grid.RowSpan="3" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <controls:PieChartControl x:Name="PortfolioPie"  x:FieldModifier="public" Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <controls:PieChartControl x:Name="AccountsPie"   x:FieldModifier="public" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <controls:PieChartControl x:Name="NarrativesPie" x:FieldModifier="public" Grid.Row="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Grid>
            <controls:Top5Control x:Name="Top5" x:FieldModifier="public" Grid.Row="3" Grid.Column="0" Margin="10,10,0,0" HorizontalAlignment="Stretch" />
            <controls:ValueGainsControl x:Name="ValueGains" x:FieldModifier="public" Grid.Row="0" Grid.Column="2" Grid.RowSpan="4" Margin="10,10,0,0" HorizontalAlignment="Stretch" />

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- Row 4 — Signals widget (Col 0-1) + Regime card (Col 2)         -->
            <!-- ═══════════════════════════════════════════════════════════════ -->

            <!-- Vandaag's signalen -->
            <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="10,4,4,4"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="10,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                        <TextBlock Text="&#x1F4CA; Vandaag's signalen"
                                   FontWeight="SemiBold" FontSize="13"
                                   Foreground="DarkGoldenrod" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind _viewModel.LastEvaluated, Mode=OneWay}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <!-- Signal rows -->
                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind _viewModel.TopSignals, Mode=OneWay}"
                              SelectionMode="None" IsItemClickEnabled="False"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewmodels:DashboardSignalRow">
                                <Grid Margin="0,2" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="44"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Coin logo -->
                                    <Image Grid.Column="0" Source="{x:Bind Image}" Width="20" Height="20"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <!-- Name + symbol -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontSize="12" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Symbol}" FontSize="10"
                                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>

                                    <!-- Direction badge -->
                                    <Border Grid.Column="2" CornerRadius="3" Padding="5,1"
                                            Background="{x:Bind DirectionBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DirectionDisplay}" FontSize="10"
                                                   FontWeight="SemiBold" Foreground="White"/>
                                    </Border>

                                    <!-- Score -->
                                    <TextBlock Grid.Column="3" Text="{x:Bind ScoreDisplay}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{x:Bind ScoreBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Marktregime-status -->
            <Border Grid.Row="4" Grid.Column="2"
                    Margin="4,4,0,4"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="10,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Text="&#x1F4C8; Marktregime"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="DarkGoldenrod" Margin="0,0,0,6"/>

                    <!-- Regime badge -->
                    <Border Grid.Row="1" CornerRadius="6" Padding="10,4"
                            HorizontalAlignment="Left" Margin="0,0,0,6"
                            Background="{x:Bind _viewModel.RegimeBrush, Mode=OneWay}">
                        <TextBlock Text="{x:Bind _viewModel.CurrentRegime, Mode=OneWay}"
                                   FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <!-- Description + Reasons -->
                    <StackPanel Grid.Row="2" Spacing="4">
                        <TextBlock Text="{x:Bind _viewModel.RegimeDescription, Mode=OneWay}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{x:Bind _viewModel.RegimeReasons, Mode=OneWay}"
                                   FontSize="11" TextWrapping="Wrap" FontFamily="Consolas"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- Row 5 — Fear &amp; Greed Index bar (Col 0-2)                   -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3"
                    Margin="10,2,0,6"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    CornerRadius="8" Padding="12,6">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                    <!-- Label -->
                    <TextBlock Text="&#x1F628; Fear &amp; Greed"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="DarkGoldenrod" VerticalAlignment="Center"/>

                    <!-- Coloured value badge -->
                    <Border CornerRadius="6" Padding="10,3"
                            Background="{x:Bind _viewModel.FearGreedBrush, Mode=OneWay}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind _viewModel.FearGreedDisplay, Mode=OneWay}"
                                   FontSize="15" FontWeight="Bold" Foreground="White"/>
                    </Border>

                    <!-- Classification -->
                    <TextBlock Text="{x:Bind _viewModel.FearGreedClassification, Mode=OneWay}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{x:Bind _viewModel.FearGreedBrush, Mode=OneWay}"
                               VerticalAlignment="Center"/>

                    <!-- Updated -->
                    <TextBlock Text="{x:Bind _viewModel.FearGreedUpdated, Mode=OneWay}"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>

</Page>
