<Page
    x:Class="CryptoPortfolioTracker.Views.SetupTrackerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewmodels="using:CryptoPortfolioTracker.ViewModels"
    xmlns:models="using:CryptoPortfolioTracker.Models"
    xmlns:converters="using:CryptoPortfolioTracker.Converters"
    xmlns:controls="using:CryptoPortfolioTracker.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="View_Loaded"
    Unloaded="View_Unloaded"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Transparent ListViewItem container — no selection chrome -->
        <Style x:Key="TransparentListViewItem" TargetType="ListViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="16,12,16,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: header -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: stats bar -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: filter buttons -->
            <RowDefinition Height="*"/>
            <!-- Row 3: list -->
            <RowDefinition Height="Auto"/>
            <!-- Row 4: status bar -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Header ───────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Setup Tracker"
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="DarkGoldenrod"/>
                <TextBlock Text="Volg of gesignaleerde setups daadwerkelijk uitspelen — en meet je win rate"
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,2,0,0"/>
                <!-- #4: gedeelde marktcontext-balk -->
                <controls:MarketContextBar HorizontalAlignment="Left" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Refresh button + timestamp -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center" HorizontalAlignment="Right">
                <TextBlock Text="{x:Bind _viewModel.PricesTimestamp, Mode=OneWay}"
                           FontSize="11"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           VerticalAlignment="Center"
                           ToolTipService.ToolTip="Tijdstip van de meest recente koersverversing"/>
                <Button Content="↻  Vernieuwen"
                        Command="{x:Bind _viewModel.RefreshCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        ToolTipService.ToolTip="Koersen en statussen handmatig verversen (gebeurt ook automatisch na elke koersupdatecyclus)"/>
            </StackPanel>
        </Grid>

        <!-- ── Row 1: Stats bar ─────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="16,12" Margin="0,0,0,10">
            <StackPanel Spacing="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Total -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind _viewModel.TotalCount, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Totaal" FontSize="11"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Watching -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind _viewModel.WatchingCount, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#60a5fa"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Watching" FontSize="11"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- In Trade -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind _viewModel.OpenCount, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#ff9800"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="In Trade" FontSize="11"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Won -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind _viewModel.WonCount, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#4caf50"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Gewonnen" FontSize="11"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Lost -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind _viewModel.LostCount, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#ef5350"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Verloren" FontSize="11"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Win rate -->
                <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                    <TextBlock Text="{x:Bind _viewModel.WinRateText, Mode=OneWay}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="{x:Bind _viewModel.WinRateColor, Mode=OneWay}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Win rate"
                               FontSize="11"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind _viewModel.WinRateTarget, Mode=OneWay}"
                               FontSize="10" Margin="0,2,0,0"
                               Foreground="{x:Bind _viewModel.WinRateColor, Mode=OneWay}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Score-kalibratie: werkelijke uitkomsten per TradabilityScore-klasse (feedback-loop) -->
            <StackPanel Spacing="4" Visibility="{x:Bind _viewModel.HasCalibration, Mode=OneWay}">
                <TextBlock Text="📈 Score-kalibratie — wat je gevolgde setups in de praktijk deden per scoreklasse"
                           FontSize="11" FontWeight="SemiBold" Opacity="0.85"
                           ToolTipService.ToolTip="Werkelijk behaalde win-rate en gemiddelde R per TradabilityScore-klasse, berekend uit je gesloten (Won/Lost) setups. Zo zie je of een hogere score in jouw praktijk ook echt beter presteert."/>
                <ItemsControl ItemsSource="{x:Bind _viewModel.Calibration, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ScoreBucketCalibration">
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="6" Padding="10,6" MinWidth="118"
                                    Opacity="{x:Bind converters:Functions.ReliableToOpacity(IsReliable)}"
                                    ToolTipService.ToolTip="{x:Bind CountDisplay}">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{x:Bind ScoreClass}" FontSize="11" FontWeight="SemiBold" Opacity="0.7"/>
                                    <TextBlock Text="{x:Bind WinRateDisplay}" FontSize="16" FontWeight="Bold"/>
                                    <TextBlock Text="{x:Bind ExpectancyDisplay}" FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind CountDisplay}" FontSize="9" Opacity="0.55"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Row 2: Filter buttons ────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6" Margin="0,0,0,10">
            <ToggleButton Content="Alle"
                          IsChecked="{x:Bind _viewModel.FilterAll, Mode=OneWay}"
                          Click="FilterAll_Click" FontSize="12"
                          ToolTipService.ToolTip="Toon alle setups"/>
            <ToggleButton Content="👁 Watching"
                          IsChecked="{x:Bind _viewModel.FilterWatching, Mode=OneWay}"
                          Click="FilterWatching_Click" FontSize="12"
                          ToolTipService.ToolTip="Wacht op entry — prijs heeft de entry zone nog niet bereikt"/>
            <ToggleButton Content="🟡 In Trade"
                          IsChecked="{x:Bind _viewModel.FilterOpen, Mode=OneWay}"
                          Click="FilterOpen_Click" FontSize="12" Foreground="#ff9800"
                          ToolTipService.ToolTip="Entry bereikt — trade is actief, wacht op TP1 of stop-loss"/>
            <ToggleButton Content="✅ Gewonnen"
                          IsChecked="{x:Bind _viewModel.FilterWon, Mode=OneWay}"
                          Click="FilterWon_Click" FontSize="12" Foreground="#4caf50"
                          ToolTipService.ToolTip="TP1 geraakt — setup heeft uitgespeeld zoals verwacht"/>
            <ToggleButton Content="❌ Verloren"
                          IsChecked="{x:Bind _viewModel.FilterLost, Mode=OneWay}"
                          Click="FilterLost_Click" FontSize="12" Foreground="#ef5350"
                          ToolTipService.ToolTip="Stop-loss geraakt — setup heeft niet uitgespeeld"/>
            <ToggleButton Content="⏹ Verlopen"
                          IsChecked="{x:Bind _viewModel.FilterExpired, Mode=OneWay}"
                          Click="FilterExpired_Click" FontSize="12"
                          ToolTipService.ToolTip="Handmatig gesloten — setup was niet meer geldig (bijv. patroon geïnvalideerd)"/>
        </StackPanel>

        <!-- ── Row 3: Setup list ─────────────────────────────────────────────── -->

        <!-- Empty state -->
        <Border Grid.Row="3"
                Visibility="{x:Bind converters:Functions.EmptyCollectionToVisible(_viewModel.Setups), Mode=OneWay}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="32" HorizontalAlignment="Stretch">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Geen setups gevolgd"
                           FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Klik op 'Volg trade setup' bij een coin in de Pattern Trading pagina om een setup hier te volgen."
                           FontSize="12" TextWrapping="Wrap" MaxWidth="400" TextAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </Border>

        <ListView Grid.Row="3"
                  ItemsSource="{x:Bind _viewModel.Setups, Mode=OneWay}"
                  SelectionMode="None"
                  ItemContainerStyle="{StaticResource TransparentListViewItem}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:WatchedSetup">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            CornerRadius="8" Padding="14,10" Margin="0,0,0,6">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- logo -->
                                <ColumnDefinition Width="*"/>
                                <!-- name + pattern -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- levels -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- score + status -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Logo -->
                            <Image Grid.Column="0"
                                   Source="{x:Bind ImageUri}"
                                   Width="36" Height="36"
                                   VerticalAlignment="Center"/>

                            <!-- Coin name + pattern summary + current price -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind CoinName}"
                                               FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind CoinSymbol}"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <!-- Direction badge -->
                                    <Border CornerRadius="4" Padding="5,2"
                                            Background="{x:Bind converters:Functions.DirectionToBrush(Direction)}">
                                        <TextBlock Text="{x:Bind Direction}"
                                                   FontSize="10" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <!-- Bias badges -->
                                    <TextBlock Text="{x:Bind Bias1D}"
                                               FontSize="10" Opacity="0.7"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="·" FontSize="10" Opacity="0.5" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Bias4H}"
                                               FontSize="10" Opacity="0.7"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind PatternSummary}"
                                           FontSize="11"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="280"/>
                                <!-- Current live price — shown under ticker when available -->
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            Visibility="{x:Bind converters:Functions.CurrentPriceToVisible(CurrentPrice)}">
                                    <TextBlock Text="{x:Bind converters:Functions.FormatCryptoPrice(CurrentPrice)}"
                                               FontSize="12" FontWeight="SemiBold"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatEntryDistance(EntryDistancePct)}"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Key levels -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2" MinWidth="160">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Entry" FontSize="10" Width="36"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatCryptoPrice(EntryPrice)}"
                                               FontSize="11" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="SL" FontSize="10" Width="36" Foreground="#ef5350"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatCryptoPrice(StopLoss)}"
                                               FontSize="11" Foreground="#ef5350"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="TP1" FontSize="10" Width="36" Foreground="#4caf50"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatCryptoPrice(Target1)}"
                                               FontSize="11" Foreground="#4caf50"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="R/R" FontSize="10" Width="36"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatRR(RiskReward)}"
                                               FontSize="11"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Score + Status + Close info -->
                            <StackPanel Grid.Column="3" VerticalAlignment="Center"
                                        HorizontalAlignment="Right" Spacing="4" MinWidth="100">
                                <!-- Score badge -->
                                <Border CornerRadius="6" Padding="8,4"
                                        HorizontalAlignment="Right"
                                        Background="{x:Bind converters:Functions.ScoreToBrush(Score)}"
                                        ToolTipService.ToolTip="TradabilityScore (technische setup-kwaliteit) op het moment van volgen">
                                    <TextBlock Text="{x:Bind Score}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                                <!-- Fundamental quality badge (kwaliteitsoordeel uit de Fundamentals-tab) -->
                                <TextBlock Text="{x:Bind FundamentalDisplay}"
                                           FontSize="10" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           Visibility="{x:Bind HasFundamental}"
                                           ToolTipService.ToolTip="Fundamentele kwaliteitsscore (0-100) + verdict uit de Fundamentals-tab"/>
                                <!-- Status badge -->
                                <Border CornerRadius="4" Padding="6,2"
                                        HorizontalAlignment="Right"
                                        Background="{x:Bind converters:Functions.SetupStatusToBrush(Status)}"
                                        ToolTipService.ToolTip="{x:Bind converters:Functions.SetupStatusToTooltip(Status)}">
                                    <TextBlock Text="{x:Bind converters:Functions.SetupStatusToText(Status)}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                                <!-- Realized P&L — shown for Won / Lost -->
                                <StackPanel Orientation="Horizontal" Spacing="5"
                                            HorizontalAlignment="Right"
                                            Visibility="{x:Bind converters:Functions.PnlToVisible(PnlPct)}"
                                            ToolTipService.ToolTip="Gerealiseerde winst/verlies — slotkoers t.o.v. instapprijs">
                                    <TextBlock Text="P&amp;L"
                                               FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatPnlPct(PnlPct)}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{x:Bind converters:Functions.PnlToBrush(PnlPct)}"/>
                                </StackPanel>
                                <!-- Unrealised P&L — shown for Open (In Trade) -->
                                <StackPanel Orientation="Horizontal" Spacing="5"
                                            HorizontalAlignment="Right"
                                            Visibility="{x:Bind converters:Functions.PnlToVisible(UnrealisedPnlPct)}"
                                            ToolTipService.ToolTip="Ongerealiseerde winst/verlies — huidige koers t.o.v. instapprijs (trade is nog open)">
                                    <TextBlock Text="Unreal."
                                               FontSize="10"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatPnlPct(UnrealisedPnlPct)}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{x:Bind converters:Functions.PnlToBrush(UnrealisedPnlPct)}"/>
                                </StackPanel>
                                <!-- Age (setup aangemaakt) -->
                                <TextBlock Text="{x:Bind converters:Functions.FormatAge(AddedAt)}"
                                           FontSize="10" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource SystemControlForegroundBaseLowBrush}"/>
                                <!-- Instapcandle — zichtbaar zodra entry geraakt is -->
                                <StackPanel Orientation="Horizontal" Spacing="3"
                                            HorizontalAlignment="Right"
                                            Visibility="{x:Bind converters:Functions.NullableDateTimeToVisible(EntryAt)}"
                                            ToolTipService.ToolTip="Instapcandle — tijdstip waarop de koers de instapprijs bereikte">
                                    <TextBlock Text="📥" FontSize="9" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatCandleTime(EntryAt)}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#4caf50"/>
                                </StackPanel>
                                <!-- Sluitingscandle — zichtbaar bij Won / Lost / Expired -->
                                <StackPanel Orientation="Horizontal" Spacing="3"
                                            HorizontalAlignment="Right"
                                            Visibility="{x:Bind converters:Functions.NullableDateTimeToVisible(ClosedAt)}"
                                            ToolTipService.ToolTip="Sluitingscandle — tijdstip waarop TP1 of SL werd geraakt">
                                    <TextBlock Text="📤" FontSize="9" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind converters:Functions.FormatCandleTime(ClosedAt)}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#ef5350"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Action buttons -->
                            <StackPanel Grid.Column="4" Orientation="Vertical"
                                        VerticalAlignment="Center" Spacing="4">
                                <!-- Manual Won — only for Watching / Open -->
                                <Button Content="✅ Gewonnen"
                                        FontSize="11"
                                        Tag="{x:Bind}"
                                        Click="CloseAsWon_Click"
                                        Visibility="{x:Bind converters:Functions.IsWatchingToVisible(Status)}"
                                        ToolTipService.ToolTip="Markeer handmatig als Gewonnen — sluit de setup op de huidige koers"/>
                                <!-- Manual Lost — only for Watching / Open -->
                                <Button Content="❌ Verloren"
                                        FontSize="11"
                                        Tag="{x:Bind}"
                                        Click="CloseAsLost_Click"
                                        Visibility="{x:Bind converters:Functions.IsWatchingToVisible(Status)}"
                                        ToolTipService.ToolTip="Markeer handmatig als Verloren — sluit de setup op de huidige koers"/>
                                <!-- Expire — only for Watching / Open -->
                                <Button Content="⏹ Verlopen"
                                        FontSize="11"
                                        Tag="{x:Bind}"
                                        Click="Expire_Click"
                                        Visibility="{x:Bind converters:Functions.IsWatchingToVisible(Status)}"
                                        ToolTipService.ToolTip="Markeer als verlopen — het patroon is geïnvalideerd of niet meer relevant"/>
                                <!-- Remove — always visible -->
                                <Button Content="🗑 Verwijder"
                                        FontSize="11"
                                        Tag="{x:Bind}"
                                        Click="Remove_Click"
                                        ToolTipService.ToolTip="Verwijder deze setup permanent uit het overzicht"/>
                            </StackPanel>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- ── Row 4: Status text ────────────────────────────────────────────── -->
        <TextBlock Grid.Row="4"
                   Text="{x:Bind _viewModel.StatusText, Mode=OneWay}"
                   FontSize="11" Margin="2,4,0,0"
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>

    </Grid>
</Page>
