<Page
    x:Class="CryptoPortfolioTracker.Views.TradeAnalysisView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CryptoPortfolioTracker.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="View_Loaded"
    Unloaded="View_Unloaded"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid x:Name="RootGrid" CornerRadius="8,8,0,0"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Margin="0,0,5,10" VerticalAlignment="Stretch">

            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Background header image — only behind the title row -->
            <controls:HomePageHeaderImage Grid.Row="0" Height="100" VerticalAlignment="Stretch"/>

            <!-- Page header -->
            <RelativePanel Grid.Row="0">
                <TextBlock AutomationProperties.AutomationId="__ClickableAreaTextBlock"/>
                <TextBlock x:Name="AppTitleText"
                           Text="Crypto Portfolio Tracker Plus"
                           Foreground="DarkGoldenrod"
                           Margin="36,0,0,0"
                           VerticalAlignment="Top"
                           Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Name="PortfolioNameText"
                           Text="{x:Bind _vm.PortfolioName, Mode=OneWay}"
                           Foreground="DarkGoldenrod"
                           Margin="36,0,0,0"
                           Style="{StaticResource SubSampleHeaderTextStyle}"
                           RelativePanel.Below="AppTitleText"/>
                <TextBlock x:Name="PageTitleText"
                           Text="Trade Advies"
                           Foreground="DarkGoldenrod"
                           Margin="36,5,0,0"
                           Style="{StaticResource SampleHeaderTextStyle}"
                           RelativePanel.Below="PortfolioNameText"/>
            </RelativePanel>

            <!-- Controls row — solid background so controls are always readable -->
            <Border Grid.Row="1"
                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                    BorderBrush="{ThemeResource SystemControlBackgroundChromeMediumBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="35,10,20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: coin picker + analyse buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

                        <!-- Coin picker -->
                        <ComboBox x:Name="CoinPicker"
                                  ItemsSource="{x:Bind _vm.Coins, Mode=OneWay}"
                                  SelectedItem="{x:Bind _vm.SelectedCoin, Mode=TwoWay}"
                                  MinWidth="200"
                                  PlaceholderText="Selecteer een coin...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Image Source="{Binding ImageUri}" Width="18" Height="18"
                                               VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Symbol}" Foreground="Gray"
                                                   VerticalAlignment="Center" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- Analyseer (single coin) -->
                        <Button Content="Analyseer"
                                Command="{x:Bind _vm.AnalyzeCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                MinWidth="100"
                                ToolTipService.ToolTip="Analyseer de geselecteerde coin"/>

                        <!-- Analyseer alles -->
                        <Button x:Name="AnalyzeAllButton"
                                Command="{x:Bind _vm.AnalyzeAllCommand}"
                                MinWidth="130"
                                ToolTipService.ToolTip="Analyseer alle coins en sorteer op signaalsterkte">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="12"/>
                                <TextBlock Text="Analyseer alles" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Copy to clipboard (single analysis only) -->
                        <Button x:Name="CopyButton"
                                Content="📋  Kopieer"
                                Click="CopyButton_Click"
                                IsEnabled="False"
                                MinWidth="100"
                                ToolTipService.ToolTip="Kopieer analyse naar klembord (Discord-formaat)"/>
                    </StackPanel>

                    <!-- Right: progress + status -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <ProgressRing IsActive="{x:Bind _vm.IsLoading, Mode=OneWay}"
                                      Width="20" Height="20" VerticalAlignment="Center"/>
                        <ProgressRing IsActive="{x:Bind _vm.IsAnalyzingAll, Mode=OneWay}"
                                      Width="20" Height="20" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind _vm.StatusMessage, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="480"/>
                        <!-- #1: fundamenteel kwaliteitsoordeel van de geanalyseerde coin -->
                        <Border CornerRadius="6" Padding="8,3" VerticalAlignment="Center"
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                Visibility="{x:Bind _vm.HasFundamental, Mode=OneWay}"
                                ToolTipService.ToolTip="Fundamentele kwaliteitsscore (0-100) + verdict uit de Fundamentals-tab">
                            <TextBlock Text="{x:Bind _vm.FundamentalDisplay, Mode=OneWay}"
                                       FontSize="12" FontWeight="SemiBold" Foreground="DarkGoldenrod"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content area — two tabs: Overzicht (ranked list) + Analyse (single coin) -->
            <Pivot Grid.Row="2" x:Name="ContentPivot" Margin="16,0,16,0">

                <PivotItem Header="Overzicht">
                    <ScrollViewer VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  Padding="10,8,10,24">
                        <StackPanel x:Name="OverviewPanel" Spacing="0"/>
                    </ScrollViewer>
                </PivotItem>

                <PivotItem Header="Analyse">
                    <ScrollViewer VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollMode="Disabled"
                                  Padding="10,8,10,24">
                        <StackPanel x:Name="AnalysisPanel" Spacing="0"/>
                    </ScrollViewer>
                </PivotItem>

            </Pivot>

        </Grid>
    </Grid>
</Page>
