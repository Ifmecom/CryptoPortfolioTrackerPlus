<Page
    x:Class="CryptoPortfolioTracker.Views.StatisticsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:CryptoPortfolioTracker.ViewModels"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    Loaded="View_Loaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Statistieken"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       VerticalAlignment="Center"/>

            <!-- Trade-kind selector (Alle / Live / Paper) -->
            <ComboBox Grid.Column="1"
                      Margin="0,0,8,0"
                      MinWidth="120"
                      VerticalAlignment="Center"
                      ToolTipService.ToolTip="Filter op trade-type"
                      ItemsSource="{x:Bind _viewModel.TradeKindOptions}"
                      SelectedItem="{x:Bind _viewModel.SelectedTradeKind, Mode=TwoWay}"/>

            <!-- Period selector -->
            <ComboBox Grid.Column="2"
                      Margin="0,0,8,0"
                      MinWidth="180"
                      VerticalAlignment="Center"
                      ItemsSource="{x:Bind _viewModel.PeriodOptions}"
                      SelectedItem="{x:Bind _viewModel.SelectedPeriod, Mode=TwoWay}"/>

            <!-- Refresh button -->
            <Button Grid.Column="3"
                    VerticalAlignment="Center"
                    Command="{x:Bind _viewModel.RefreshCommand}"
                    ToolTipService.ToolTip="Herlaad statistieken">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="13"/>
                    <TextBlock Text="Vernieuwen"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Loading indicator -->
        <ProgressBar Grid.Row="0"
                     VerticalAlignment="Bottom"
                     IsIndeterminate="True"
                     Visibility="{x:Bind _viewModel.IsLoading, Mode=OneWay}"/>

        <!-- ── Custom date range row (only visible when "Aangepast") ───── -->
        <Border Grid.Row="1"
                Padding="16,0,16,10"
                Visibility="{x:Bind _viewModel.IsCustomPeriod, Mode=OneWay}">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="Van:"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <DatePicker Date="{x:Bind _viewModel.CustomStartDate, Mode=TwoWay}"/>
                <TextBlock Text="Tot:"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                <DatePicker Date="{x:Bind _viewModel.CustomEndDate, Mode=TwoWay}"/>
            </StackPanel>
        </Border>

        <!-- ── Content ─────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2" Padding="16,0,16,16">
            <StackPanel Spacing="16">

                <!-- Status bar -->
                <TextBlock Text="{x:Bind _viewModel.StatusMessage, Mode=OneWay}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Margin="0,0,0,4"/>

                <!-- ── Summary cards ──────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total P&L -->
                    <Border Grid.Column="0" Margin="0,0,6,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Totale P&amp;L"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind _viewModel.TotalPnlDisplay, Mode=OneWay}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{x:Bind _viewModel.TotalPnlBrush, Mode=OneWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- Win rate -->
                    <Border Grid.Column="1" Margin="3,0,3,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Win rate"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind _viewModel.WinRateDisplay, Mode=OneWay}"
                                       FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind _viewModel.TradeCountDisplay, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Avg win / loss -->
                    <Border Grid.Column="2" Margin="3,0,3,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Gem. winst / verlies"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind _viewModel.AvgWinDisplay, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#3CB371"/>
                            <TextBlock Text="{x:Bind _viewModel.AvgLossDisplay, Mode=OneWay}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="#CD5C5C"/>
                        </StackPanel>
                    </Border>

                    <!-- Open trades / volume -->
                    <Border Grid.Column="3" Margin="6,0,0,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Open posities"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind _viewModel.OpenTradesDisplay, Mode=OneWay}"
                                       FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind _viewModel.TotalVolumeDisplay, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       ToolTipService.ToolTip="Totaal verhandeld volume (gesloten trades)"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Pie charts row ─────────────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Win / Loss pie -->
                    <Border Grid.Column="0" Margin="0,0,6,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Winst / Verlies"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       HorizontalAlignment="Center"/>
                            <lvc:PieChart
                                Series="{x:Bind _viewModel.WinLossSeries, Mode=OneWay}"
                                Height="200"/>
                        </StackPanel>
                    </Border>

                    <!-- Long / Short pie -->
                    <Border Grid.Column="1" Margin="3,0,3,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Long / Short"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       HorizontalAlignment="Center"/>
                            <lvc:PieChart
                                Series="{x:Bind _viewModel.SideSeries, Mode=OneWay}"
                                Height="200"/>
                        </StackPanel>
                    </Border>

                    <!-- Paper / Live pie -->
                    <Border Grid.Column="2" Margin="6,0,0,0"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Paper / Live"
                                       Style="{ThemeResource SubtitleTextBlockStyle}"
                                       HorizontalAlignment="Center"/>
                            <lvc:PieChart
                                Series="{x:Bind _viewModel.KindSeries, Mode=OneWay}"
                                Height="200"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Best / worst symbols table ────────────────────── -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="16,12">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Top symbols (gesloten trades)"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"/>

                        <!-- Header row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Symbol"        FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                            <TextBlock Grid.Column="1" Text="Trades"        FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="Totale P&amp;L" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Win rate"      FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                        </Grid>

                        <MenuFlyoutSeparator/>

                        <ListView ItemsSource="{x:Bind _viewModel.TopSymbols, Mode=OneWay}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  MinHeight="40">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0,4"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:SymbolStatRow">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{x:Bind Symbol}"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Trades}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind PnlDisplay}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{x:Bind PnlBrushCached}"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{x:Bind WinRateDisplay}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
