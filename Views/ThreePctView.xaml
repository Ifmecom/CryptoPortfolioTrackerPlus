<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CryptoPortfolioTracker.Views.ThreePctView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CryptoPortfolioTracker.ViewModels"
    xmlns:models="using:CryptoPortfolioTracker.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="View_Loaded"
    Unloaded="View_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="16,12,16,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                <TextBlock Text="3% Trading"
                           Style="{ThemeResource TitleTextBlockStyle}"
                           Foreground="DarkGoldenrod"/>
                <TextBlock Text="Gekalibreerd scoremodel — netto +3% target na fees en slippage"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>

            <!-- IsLoading indicator -->
            <ProgressBar Grid.Column="0" Grid.ColumnSpan="2"
                         VerticalAlignment="Bottom"
                         IsIndeterminate="True"
                         Visibility="{x:Bind _viewModel.IsLoading, Mode=OneWay}"/>
        </Grid>

        <!-- ── Pivot ───────────────────────────────────────────────────────── -->
        <Pivot Grid.Row="1" Margin="8,0,8,0">

            <!-- ═══════════════════════════════════════════════════════════════
                 TAB 1 — Fase 1: Kalibratie / Backtest
                 ═══════════════════════════════════════════════════════════════ -->
            <PivotItem Header="Fase 1 — Kalibratie">
                <ScrollViewer Padding="8,8,8,16">
                    <StackPanel Spacing="14">

                        <!-- Uitleg -->
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 Title="Wat doet deze fase?"
                                 Message="Loop door maximaal 1000 historische candles, simuleer per signaal of +3% netto (TP) of de SL eerst geraakt wordt, en geef de gecalibreerde hitrate per scoreklasse terug. Run deze fase wekelijks of na een trendwisseling."/>

                        <!-- ── Instellingen ─────────────────────────────────────────────── -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <Grid ColumnSpacing="12" RowSpacing="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Row 0: labels -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Backtest-symbool"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"
                                           ToolTipService.ToolTip="Het Binance-handelspaar waarop de kalibratie draait, bijv. BTCUSDT. Kies een liquide munt met lange historie voor een betrouwbare kalibratie."/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Timeframe"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"
                                           ToolTipService.ToolTip="Candle-interval (1d / 4h / 1h). Moet gelijk zijn aan het interval dat je in de live scan gebruikt."/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Richting"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"
                                           ToolTipService.ToolTip="Long, Short of beide. Bepaalt welke kant van de trade wordt gesimuleerd in de backtest."/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Netto TP %"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"
                                           ToolTipService.ToolTip="Doelwinst na aftrek van fees en slippage (standaard 3%). De brutowinst die nodig is ligt hoger, want fees en slippage worden eraf getrokken."/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="Fee % (per zijde)"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"
                                           ToolTipService.ToolTip="Handelskosten per zijde (maker/taker). Wordt twee keer gerekend (in- en uitstap) bij het bepalen van de bruto-TP."/>

                                <!-- Row 1: inputs -->
                                <TextBox Grid.Row="1" Grid.Column="0"
                                         Text="{x:Bind _viewModel.BacktestSymbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="bv. BTCUSDT"/>
                                <ComboBox Grid.Row="1" Grid.Column="1"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind _viewModel.TimeframeOptions}"
                                          SelectedItem="{x:Bind _viewModel.SelectedTimeframe, Mode=TwoWay}"/>
                                <ComboBox Grid.Row="1" Grid.Column="2"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind _viewModel.BiasOptions}"
                                          SelectedItem="{x:Bind _viewModel.SelectedBias, Mode=TwoWay}"/>
                                <NumberBox Grid.Row="1" Grid.Column="3"
                                           Value="{x:Bind _viewModel.TpNetPct, Mode=TwoWay}"
                                           Minimum="0.5" Maximum="20" SmallChange="0.1"
                                           SpinButtonPlacementMode="Inline"/>
                                <NumberBox Grid.Row="1" Grid.Column="4"
                                           Value="{x:Bind _viewModel.FeePct, Mode=TwoWay}"
                                           Minimum="0" Maximum="1" SmallChange="0.01"
                                           SpinButtonPlacementMode="Inline"/>

                                <!-- Row 2: extra settings -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4"
                                            ToolTipService.ToolTip="Afstand van de stop-loss als veelvoud van de ATR (volatiliteit). 1,5× is standaard — kleiner = krappere stop, vaker uitgestopt.">
                                    <TextBlock Text="SL-factor (× ATR)"
                                               Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                                    <NumberBox Value="{x:Bind _viewModel.SlAtrMultiple, Mode=TwoWay}"
                                               Minimum="0.5" Maximum="4" SmallChange="0.1"
                                               SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4"
                                            ToolTipService.ToolTip="Maximaal aantal candles waarbinnen TP of SL geraakt moet worden. Wordt geen van beide bereikt, dan telt de trade niet mee (timeout).">
                                    <TextBlock Text="Max horizon (bars)"
                                               Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                                    <NumberBox Value="{x:Bind _viewModel.MaxHorizonBars, Mode=TwoWay}"
                                               Minimum="3" Maximum="50" SmallChange="1"
                                               SpinButtonPlacementMode="Inline"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Actieknoppen + voortgang ─────────────────────────────────── -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Command="{x:Bind _viewModel.RunBacktestCommand}"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="13"/>
                                    <TextBlock Text="Backtest uitvoeren"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Command="{x:Bind _viewModel.CancelBacktestCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" FontSize="13"/>
                                    <TextBlock Text="Stop"/>
                                </StackPanel>
                            </Button>

                            <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind _viewModel.BacktestStatus, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <ProgressBar Value="{x:Bind _viewModel.BacktestProgress, Mode=OneWay}"
                                             Minimum="0" Maximum="100"
                                             Visibility="{x:Bind _viewModel.IsBacktestRunning, Mode=OneWay}"/>
                            </StackPanel>
                        </Grid>

                        <!-- ── Kalibratie-info ──────────────────────────────────────────── -->
                        <TextBlock Text="{x:Bind _viewModel.CalibrationInfo, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- ── Kalibratietabel ──────────────────────────────────────────── -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Kalibratietabel — statistieken per scoreklasse"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"/>

                                <!-- Header -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Scoreklasse" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"
                                               ToolTipService.ToolTip="Bandbreedte van de modelscore (0-40 / 41-60 / 61-80 / 81-100). Een hogere klasse hoort idealiter een hogere hitrate te hebben."/>
                                    <TextBlock Grid.Column="1" Text="# Trades"   FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Aantal gesimuleerde trades in deze scoreklasse. Onder de 30 is de uitkomst statistisch onbetrouwbaar."/>
                                    <TextBlock Grid.Column="2" Text="Hitrate %"  FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Percentage trades dat de netto-TP (+3%) bereikte vóór de stop-loss. Dit is de gemeten 'kans' voor deze scoreklasse."/>
                                    <TextBlock Grid.Column="3" Text="Gem. R"     FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Gemiddeld behaald resultaat per trade in R (1R = het risico tussen entry en stop-loss). Winst en verlies samen gemiddeld."/>
                                    <TextBlock Grid.Column="4" Text="Expectancy" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Verwachte opbrengst per trade in R: (hitrate × gem. winst-R) − (verliesrate × 1R). Positief = statistische edge."/>
                                    <TextBlock Grid.Column="5" Text="Bruikbaar?" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="True wanneer er ≥ 30 trades in deze klasse zaten — anders is de hitrate slechts indicatief (overfitting-risico)."/>
                                </Grid>
                                <MenuFlyoutSeparator/>

                                <ListView ItemsSource="{x:Bind _viewModel.CalibrationRows, Mode=OneWay}"
                                          SelectionMode="None" IsItemClickEnabled="False" MinHeight="40">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0,5"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ScoreClassCalibration">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind ScoreClass}"
                                                           FontFamily="Consolas" FontSize="13" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{x:Bind TradeCount}"
                                                           FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{x:Bind HitratePct}"/><Run Text="%"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="3"
                                                           FontSize="13" FontFamily="Consolas"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{x:Bind AvgRMultiple}"/><Run Text="R"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="4"
                                                           FontSize="13" FontWeight="SemiBold" FontFamily="Consolas"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Run Text="{x:Bind Expectancy}"/><Run Text="R"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="5"
                                                           FontSize="12"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           Text="{x:Bind IsReliable}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextWrapping="Wrap"
                                           Text="⚠ Scoreklassen met minder dan 30 trades zijn statistisch onbetrouwbaar. Interpreteer de hitrate van die klassen als indicatief, niet als bewezen edge."/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ═══════════════════════════════════════════════════════════════
                 TAB 2 — Fase 2: Live Scan
                 ═══════════════════════════════════════════════════════════════ -->
            <PivotItem Header="Fase 2 — Live Scan">
                <ScrollViewer Padding="8,8,8,16">
                    <StackPanel Spacing="14">

                        <!-- Uitleg -->
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 Title="Live beoordeling"
                                 Message="Scant alle coins in je portfolio op het 5-factor scoremodel en koppelt de score aan de gecalibreerde hitrate uit Fase 1. F6 (liquiditeit) en F7 (positionering) fungeren als gatekeeper — setups met te lage F6/F7 worden gefilterd. Run eerst Fase 1 voor de kalibratie."/>

                        <!-- ── Marktregime (Sprint B) ─────────────────────────────────────── -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <Grid ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4"
                                            ToolTipService.ToolTip="Het huidige marktklimaat (RiskOn / Neutral / RiskOff) op basis van BTC. In een RiskOff-regime zijn long-setups risicovoller.">
                                    <TextBlock Text="Regime"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.RegimeSummary, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4"
                                            ToolTipService.ToolTip="Stand van BTC's 50- vs 200-daags voortschrijdend gemiddelde. Golden Cross (50 boven 200) = bullish structuur, Death Cross = bearish.">
                                    <TextBlock Text="EMA50/200"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.RegimeEmaCross, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4"
                                            ToolTipService.ToolTip="Aandeel van BTC in de totale cryptomarktkapitalisatie. Hoge dominantie (>60%) betekent dat alts doorgaans achterblijven; lage dominantie wijst op een altseason.">
                                    <TextBlock Text="BTC Dominantie"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.RegimeDominance, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4"
                                            ToolTipService.ToolTip="Relative Strength Index van BTC (14 perioden). Boven 70 = overbought, onder 30 = oversold; ≥ 80 dempt het RiskOn-regime naar Neutral.">
                                    <TextBlock Text="BTC RSI (14)"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.RegimeBtcRsi, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Button Grid.Column="4" VerticalAlignment="Center"
                                        Command="{x:Bind _viewModel.LoadRegimeContextCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <ProgressRing IsActive="{x:Bind _viewModel.IsRegimeLoading, Mode=OneWay}"
                                                      Width="14" Height="14"/>
                                        <TextBlock Text="Vernieuwen"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Scan-instellingen -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4"
                                        ToolTipService.ToolTip="Candle-interval voor de scan. Gebruik hetzelfde interval als waarop je Fase 1 hebt gekalibreerd, anders kloppen de hitrates niet.">
                                <TextBlock Text="Timeframe"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind _viewModel.TimeframeOptions}"
                                          SelectedItem="{x:Bind _viewModel.SelectedTimeframe, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4"
                                        ToolTipService.ToolTip="Welke richting gescand wordt: alleen Long, alleen Short, of beide (elke munt wordt dan in beide richtingen beoordeeld).">
                                <TextBlock Text="Richting"
                                           Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind _viewModel.BiasOptions}"
                                          SelectedItem="{x:Bind _viewModel.LiveScanBias, Mode=TwoWay}"/>
                            </StackPanel>

                            <Button Grid.Column="2" VerticalAlignment="Bottom"
                                    Command="{x:Bind _viewModel.RunLiveScanCommand}"
                                    Style="{ThemeResource AccentButtonStyle}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="13"/>
                                    <TextBlock Text="Scan starten"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" VerticalAlignment="Bottom"
                                    Command="{x:Bind _viewModel.CancelLiveScanCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" FontSize="13"/>
                                    <TextBlock Text="Stop"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Column="4" VerticalAlignment="Bottom"
                                       Text="{x:Bind _viewModel.LiveScanStatus, Mode=OneWay}"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                       Margin="12,0,0,4"/>
                        </Grid>

                        <!-- ── Resultaten-tabel ─────────────────────────────────────────── -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="Setups met positieve expectancy (gesorteerd op verwachte R per trade)"
                                               Style="{ThemeResource SubtitleTextBlockStyle}"/>
                                </StackPanel>

                                <!-- Diversified shortlist info (Sprint C) -->
                                <TextBlock Text="{x:Bind _viewModel.DiversifiedInfo, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="DarkGoldenrod"
                                           TextWrapping="Wrap"
                                           Visibility="{x:Bind _viewModel.HasDiversifiedInfo, Mode=OneWay}"/>

                                <!-- Header -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="54"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="48"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"  Text="Coin"       FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"
                                               ToolTipService.ToolTip="Het symbool van de munt. Beweeg over een rij voor de volledige factoruitsplitsing."/>
                                    <TextBlock Grid.Column="1"  Text="Score"      FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="De gewogen modelscore (0-100) uit de 5 technische factoren. Hoger = sterker signaal, maar de werkelijke kans volgt uit de hitrate-kolom."/>
                                    <TextBlock Grid.Column="2"  Text="Klasse"     FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"
                                               ToolTipService.ToolTip="De scoreklasse (0-40 / 41-60 / 61-80 / 81-100) waarmee de score aan de kalibratietabel uit Fase 1 wordt gekoppeld."/>
                                    <TextBlock Grid.Column="3"  Text="Hitrate"    FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="De historische netto-hitrate van deze scoreklasse uit Fase 1 — dit is de gemeten kans, geen aanname."/>
                                    <TextBlock Grid.Column="4"  Text="Expect."    FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Verwachte opbrengst per trade in R, uit de kalibratie. Setups zonder positieve expectancy worden niet aanbevolen."/>
                                    <TextBlock Grid.Column="5"  Text="Bias"       FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center"
                                               ToolTipService.ToolTip="De richting van de setup: Long (koop) of Short (verkoop)."/>
                                    <TextBlock Grid.Column="6"  Text="Entry"      FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Voorgestelde instapprijs (de laatste slotkoers op het moment van scannen)."/>
                                    <TextBlock Grid.Column="7"  Text="SL"         FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                                               ToolTipService.ToolTip="Structurele stop-loss op 1,5× ATR afstand van de entry (volatiliteitsgebaseerd, geen rond percentage)."/>
                                    <TextBlock Grid.Column="8"  Text="TP"         FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" ToolTipService.ToolTip="Take-profit op +3% netto na fees en slippage."/>
                                    <TextBlock Grid.Column="9"  Text="R/R"        FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" ToolTipService.ToolTip="Reward/Risk-verhouding: beloning (TP-afstand) gedeeld door risico (SL-afstand). Hoger is gunstiger; onder 1,5 is krap."/>
                                    <TextBlock Grid.Column="10" Text="F6"         FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" ToolTipService.ToolTip="Factor 6 — Liquiditeit (0-10): bid-ask spread en orderboekdiepte. Onder 4 wordt de setup gefilterd."/>
                                    <TextBlock Grid.Column="11" Text="F7"         FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" ToolTipService.ToolTip="Factor 7 — Positionering (0-10): funding rate en long/short-ratio. Onder 3 wordt de setup gefilterd."/>
                                    <TextBlock Grid.Column="12" Text="BTC-corr"   FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" ToolTipService.ToolTip="Pearson-correlatie van de dagrendementen met BTC (60 dagen). Hoog (>0,8) = beweegt vrijwel gelijk met BTC."/>
                                    <TextBlock Grid.Column="13" Text="★"          FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" ToolTipService.ToolTip="Gediversifieerde shortlist-keuze: een van de max. 5 setups met onderling lage correlatie."/>
                                    <TextBlock Grid.Column="14" Text=""            FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </Grid>
                                <MenuFlyoutSeparator/>

                                <ListView ItemsSource="{x:Bind _viewModel.LiveRows, Mode=OneWay}"
                                          SelectionMode="None" IsItemClickEnabled="False" MinHeight="40">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0,5"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:ThreePctLiveRow">
                                            <Grid ToolTipService.ToolTip="{x:Bind FactorBreakdown}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="75"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="58"/>
                                                    <ColumnDefinition Width="70"/>
                                                    <ColumnDefinition Width="75"/>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="94"/>
                                                    <ColumnDefinition Width="94"/>
                                                    <ColumnDefinition Width="94"/>
                                                    <ColumnDefinition Width="54"/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="40"/>
                                                    <ColumnDefinition Width="48"/>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Symbol}"
                                                               FontFamily="Consolas" FontSize="12"/>
                                                    <!-- #1: fundamenteel kwaliteitsoordeel -->
                                                    <TextBlock Text="{x:Bind FundamentalDisplay}"
                                                               Visibility="{x:Bind HasFundamental}"
                                                               FontSize="9" Opacity="0.85" Foreground="DarkGoldenrod"
                                                               ToolTipService.ToolTip="Fundamentele kwaliteitsscore (0-100) + verdict uit de Fundamentals-tab"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind ScoreDisplay}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{x:Bind ScoreClass}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="{x:Bind HitrateDisplay}"
                                                           FontSize="12"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4"
                                                           Text="{x:Bind ExpectancyDisplay}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           FontFamily="Consolas"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="5"
                                                           Text="{x:Bind Bias}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="6"
                                                           Text="{x:Bind EntryDisplay}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="7"
                                                           Text="{x:Bind SLDisplay}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="#CD5C5C"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="8"
                                                           Text="{x:Bind TPDisplay}"
                                                           FontFamily="Consolas" FontSize="11"
                                                           Foreground="#3CB371"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="9"
                                                           Text="{x:Bind RRDisplay}"
                                                           FontSize="11"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="10"
                                                           Text="{x:Bind F6Display}"
                                                           FontSize="11" FontFamily="Consolas"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="11"
                                                           Text="{x:Bind F7Display}"
                                                           FontSize="11" FontFamily="Consolas"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="12"
                                                           Text="{x:Bind CorrDisplay}"
                                                           FontSize="11" FontFamily="Consolas"
                                                           HorizontalAlignment="Right"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="13"
                                                           Text="{x:Bind DiversifiedDisplay}"
                                                           FontSize="12"
                                                           Foreground="DarkGoldenrod"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="14" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                                    <Button Content="Detail"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            CommandParameter="{x:Bind}"
                                                            Command="{Binding DataContext.ShowDetailCommand, ElementName=RootPage}"/>
                                                    <Button Content="Paper"
                                                            FontSize="11"
                                                            Padding="6,2"
                                                            ToolTipService.ToolTip="Activeer deze setup als paper trade om de strategie met live data te forward-testen."
                                                            CommandParameter="{x:Bind}"
                                                            Command="{Binding DataContext.OpenPaperTradeCommand, ElementName=RootPage}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextWrapping="Wrap"
                                           Text="ℹ Scores en hitrates zijn modeluitkomsten op basis van historische kalibratie — geen garanties. Reken altijd netto na fees. F6 (liquiditeit) en F7 (positionering) zijn sprint B gatekeepers: &lt;4 of &lt;3 filtert de setup. De kalibratie is gebaseerd op het 5-factor model zodat historische vergelijkbaarheid gewaarborgd blijft."/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- ═══════════════════════════════════════════════════════════════
                 TAB 3 — Paper Trades (forward-test met live data)
                 ═══════════════════════════════════════════════════════════════ -->
            <PivotItem Header="Paper Trades">
                <ScrollViewer Padding="8,8,8,16">
                    <StackPanel Spacing="14">

                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 Title="Forward-test met live data"
                                 Message="Hier verschijnen alle paper trades die je vanuit de Live Scan hebt geactiveerd. Druk op Vernieuwen om pending limit-orders te vullen en TP/SL te laten triggeren op de actuele koers — zo test je of de strategie in de praktijk werkt zonder echt geld te riskeren."/>

                        <!-- ── Samenvatting + acties ──────────────────────────────────────── -->
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Margin="0,0,6,0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12"
                                    ToolTipService.ToolTip="Totaal aantal 3%-paper trades en hoeveel er nog open staan (pending of gevuld).">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Trades" Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.PaperCountDisplay, Mode=OneWay}"
                                               FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Margin="3,0,3,0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12"
                                    ToolTipService.ToolTip="Win rate over de gesloten paper trades: gewonnen / (gewonnen + verloren). De kerntest of de strategie werkt.">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Win rate (gesloten)" Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.PaperWinRateDisplay, Mode=OneWay}"
                                               FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Margin="3,0,3,0"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="16,12"
                                    ToolTipService.ToolTip="Totale P&amp;L in USDT: gerealiseerd (gesloten trades) plus ongerealiseerd (open trades op de huidige koers).">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Totale P&amp;L" Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                    <TextBlock Text="{x:Bind _viewModel.PaperPnlDisplay, Mode=OneWay}"
                                               FontSize="18" FontWeight="SemiBold"
                                               Foreground="{x:Bind _viewModel.PaperPnlBrush, Mode=OneWay}"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Column="3" VerticalAlignment="Center"
                                    Command="{x:Bind _viewModel.RefreshPaperTradesCommand}"
                                    Style="{ThemeResource AccentButtonStyle}"
                                    ToolTipService.ToolTip="Vul pending orders en sluit getriggerde TP/SL op de actuele koers, en herlaad de lijst.">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <ProgressRing IsActive="{x:Bind _viewModel.IsPaperLoading, Mode=OneWay}" Width="14" Height="14"/>
                                    <TextBlock Text="Vernieuwen"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="{x:Bind _viewModel.PaperStatus, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                   TextWrapping="Wrap"/>

                        <!-- ── Tabel met 3%-paper trades ──────────────────────────────────── -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Geactiveerde paper trades"
                                           Style="{ThemeResource SubtitleTextBlockStyle}"/>

                                <!-- Header -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Symbol"   FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Grid.Column="1" Text="Zijde"    FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Grid.Column="2" Text="Entry"    FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="SL"       FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="TP"       FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="5" Text="Koers nu" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="Status"   FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Grid.Column="7" Text="P&amp;L"  FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="8" Text="Aangemaakt" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                    <TextBlock Grid.Column="9" Text=""         FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}"/>
                                </Grid>
                                <MenuFlyoutSeparator/>

                                <ListView ItemsSource="{x:Bind _viewModel.PaperTradeRows, Mode=OneWay}"
                                          SelectionMode="None" IsItemClickEnabled="False" MinHeight="40">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="0,5"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="MinHeight" Value="0"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TradeJournalRow">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Symbol}"             FontFamily="Consolas" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{x:Bind Side}"               FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{x:Bind EntryDisplay}"       FontFamily="Consolas" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{x:Bind SlDisplay}"          FontFamily="Consolas" FontSize="12" Foreground="#CD5C5C" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" Text="{x:Bind TpDisplay}"          FontFamily="Consolas" FontSize="12" Foreground="#3CB371" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="5" Text="{x:Bind CurrentPriceDisplay}" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="6" Text="{x:Bind Status}"            FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="7" Text="{x:Bind PnlDisplay}"        FontFamily="Consolas" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{x:Bind PnlBrush}"/>
                                                <TextBlock Grid.Column="8" Text="{x:Bind CreatedDisplay}"    FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="9"
                                                        Content="Sluit"
                                                        FontSize="11" Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        IsEnabled="{x:Bind IsActionable}"
                                                        ToolTipService.ToolTip="Sluit deze open positie op de huidige koers (of annuleer een nog niet gevulde order)."
                                                        CommandParameter="{x:Bind}"
                                                        Command="{Binding DataContext.ClosePaperTradeCommand, ElementName=RootPage}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           TextWrapping="Wrap"
                                           Text="ℹ Pending limit-orders vullen automatisch zodra de koers de entry raakt; daarna sluiten ze op TP of SL. Druk regelmatig op Vernieuwen om de forward-test bij te werken. Deze trades verschijnen ook in het normale Trade Journal."/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>
    </Grid>
</Page>
