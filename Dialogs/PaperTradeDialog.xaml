<ContentDialog
    x:Class="CryptoPortfolioTracker.Dialogs.PaperTradeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    DefaultButton="Primary"
    Loading="Dialog_Loading">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">460</x:Double>
    </ContentDialog.Resources>

    <Grid Width="400" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Coin info banner -->
        <Border Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                CornerRadius="6" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock x:Name="txtSymbol" FontSize="20" FontWeight="Bold" Foreground="DarkGoldenrod"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="txtName" FontSize="13"/>
                    <TextBlock x:Name="txtPrice" FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Exchange -->
        <StackPanel Grid.Row="1" Spacing="4">
            <TextBlock Text="Exchange" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ComboBox x:Name="cmbExchange" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Bybit"  Tag="Bybit"  IsSelected="True"/>
                <ComboBoxItem Content="MEXC"   Tag="Mexc"/>
            </ComboBox>
        </StackPanel>

        <!-- Side -->
        <StackPanel Grid.Row="2" Spacing="4">
            <TextBlock Text="Side" Style="{StaticResource CaptionTextBlockStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton x:Name="rdBuy"  Content="Buy (Long)"  GroupName="Side" IsChecked="True"/>
                <RadioButton x:Name="rdSell" Content="Sell (Short)" GroupName="Side"/>
            </StackPanel>
        </StackPanel>

        <!-- Amount USDT -->
        <StackPanel Grid.Row="3" Spacing="4">
            <TextBlock Text="Amount (USDT)" Style="{StaticResource CaptionTextBlockStyle}"/>
            <NumberBox x:Name="nbAmount"
                       Minimum="1" Maximum="100000" Value="100"
                       SpinButtonPlacementMode="Inline"
                       HorizontalAlignment="Stretch"/>
        </StackPanel>

        <!-- SL / TP -->
        <Grid Grid.Row="4" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Stop Loss %" Style="{StaticResource CaptionTextBlockStyle}"/>
                <NumberBox x:Name="nbStopLoss"
                           Minimum="0.1" Maximum="50" Value="5"
                           SpinButtonPlacementMode="Inline"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock Text="Take Profit %" Style="{StaticResource CaptionTextBlockStyle}"/>
                <NumberBox x:Name="nbTakeProfit"
                           Minimum="0.1" Maximum="200" Value="10"
                           SpinButtonPlacementMode="Inline"/>
            </StackPanel>
        </Grid>

        <!-- Signal reasoning (if available) -->
        <Expander Grid.Row="5" Header="Signal reasoning" HorizontalAlignment="Stretch"
                  Visibility="{x:Bind _hasReasoning}">
            <TextBlock x:Name="txtReasoning"
                       FontSize="11" FontFamily="Consolas"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap"/>
        </Expander>
    </Grid>
</ContentDialog>
