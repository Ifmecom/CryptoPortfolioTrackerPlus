<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CryptoPortfolioTracker.Dialogs.WhatsNewDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Close"
    DefaultButton="Primary"
    Loaded="WhatsNewDialog_Loaded">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">900</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">700</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer Width="820" Height="560"
                  VerticalScrollMode="Auto"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollMode="Disabled">
        <StackPanel x:Name="ContentPanel" Margin="4,8,20,8" Spacing="0"/>
    </ScrollViewer>

</ContentDialog>
