<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CryptoPortfolioTracker.Dialogs.SetupDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:l="using:WinUI3Localizer"
    Loading="Dialog_Loading"
    mc:Ignorable="d">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">820</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">1400</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="750" Padding="4,0,8,0">
        <StackPanel x:Name="ContentPanel" Spacing="14"/>
    </ScrollViewer>

</ContentDialog>
